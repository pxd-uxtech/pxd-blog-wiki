---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — pxd 블로그 위키</title>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-L1KGH3Y3R3" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-L1KGH3Y3R3');
  </script>
  <style is:global>
    @import url('https://cdn.jsdelivr.net/gh/pxd-uxtech/KoddiUDOnGothic@main/webfont/KoddiUDOnGothic.css');

    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    html {
      font-size: 16px;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }

    body {
      font-family: 'KoddiUD OnGothic', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
      line-height: 1.7;
      color: #1d1d1f;
      background: #faf9f5;
    }

    .page-wrapper {
      max-width: 720px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }

    /* ── Header / Nav ── */
    header {
      background: #fff;
      border-bottom: 1px solid #ebe8dd;
      position: sticky;
      top: 0;
      z-index: 10;
    }

    nav {
      max-width: 720px;
      margin: 0 auto;
      padding: 0.875rem 1.5rem;
      display: flex;
      gap: 1.25rem;
      align-items: baseline;
      flex-wrap: wrap;
      position: relative;
    }

    nav .site-title {
      display: flex;
      align-items: center;
      gap: 0.5rem;
      font-size: 0.95rem;
      font-weight: 700;
      color: #1d1d1f;
      text-decoration: none;
      letter-spacing: -0.01em;
      margin-right: 0.5rem;
    }

    nav .site-title img {
      height: 22px;
      width: auto;
    }

    nav a {
      font-size: 0.8rem;
      color: #6e6e73;
      text-decoration: none;
      transition: color 0.15s;
    }

    nav a:hover {
      color: #3b82f6;
    }

    nav a[aria-current="page"],
    nav a.active {
      color: #3b82f6;
      font-weight: 600;
    }

    /* ── Search ── */
    .search-wrapper {
      margin-left: auto;
      flex-shrink: 1;
      min-width: 0;
    }

    .search-wrapper .pagefind-ui {
      --pagefind-ui-scale: 0.7;
      --pagefind-ui-primary: #3b82f6;
      --pagefind-ui-text: #1d1d1f;
      --pagefind-ui-background: #fff;
      --pagefind-ui-border: #ebe8dd;
      --pagefind-ui-border-width: 1px;
      --pagefind-ui-border-radius: 6px;
      --pagefind-ui-font: 'KoddiUD OnGothic', -apple-system, system-ui, sans-serif;
    }

    .search-wrapper .pagefind-ui .pagefind-ui__search-input {
      width: 180px;
      transition: width 0.2s;
    }

    .search-wrapper .pagefind-ui .pagefind-ui__search-input:focus {
      width: 260px;
    }

    .search-wrapper .pagefind-ui .pagefind-ui__drawer {
      position: absolute;
      right: 0;
      top: 100%;
      z-index: 100;
      background: #fff;
      border: 1px solid #ebe8dd;
      border-radius: 8px;
      box-shadow: 0 4px 16px rgba(0,0,0,0.1);
      max-height: 60vh;
      overflow-y: auto;
      width: 400px;
      max-width: 90vw;
    }

    .search-wrapper .pagefind-ui .pagefind-ui__form::before {
      display: none;
    }

    /* ── Main Content ── */
    main {
      padding: 2.5rem 0 4rem;
    }

    /* ── Typography ── */
    a { color: #3b82f6; text-decoration: none; }
    a:hover { text-decoration: underline; text-underline-offset: 2px; }

    h1 {
      font-size: 1.75rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      line-height: 1.3;
      margin-bottom: 0.5rem;
      color: #1d1d1f;
    }

    h1 + p {
      color: #6e6e73;
      font-size: 0.95rem;
      margin-bottom: 2rem;
    }

    h2 {
      font-size: 1.1rem;
      font-weight: 700;
      letter-spacing: -0.01em;
      margin-top: 2.5rem;
      margin-bottom: 0.75rem;
      color: #1d1d1f;
    }

    h2 a { color: inherit; }
    h2 a:hover { color: #3b82f6; text-decoration: none; }

    h3 {
      font-size: 0.95rem;
      font-weight: 700;
      margin-top: 1.75rem;
      margin-bottom: 0.5rem;
      color: #1d1d1f;
    }

    p {
      font-size: 0.9rem;
      color: #48484a;
      line-height: 1.7;
      margin-bottom: 0.75rem;
    }

    /* ── Tables ── */
    table {
      border-collapse: collapse;
      width: 100%;
      margin: 0.75rem 0 1.5rem;
      font-size: 0.85rem;
    }

    thead th {
      text-align: left;
      padding: 0.5rem 0.75rem;
      font-weight: 600;
      font-size: 0.75rem;
      color: #8e8e93;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      border-bottom: 2px solid #ebe8dd;
    }

    td {
      padding: 0.6rem 0.75rem;
      border-bottom: 1px solid #f0ede2;
      color: #1d1d1f;
    }

    tbody tr:hover { background: #f3f1e8; }

    /* ── Lists ── */
    ul { list-style: none; padding: 0; }

    li {
      padding: 0.4rem 0;
      font-size: 0.9rem;
      line-height: 1.5;
      border-bottom: 1px solid #f0ede2;
    }

    li:last-child { border-bottom: none; }

    /* ── Utility ── */
    .date {
      color: #8e8e93;
      font-size: 0.78rem;
      font-variant-numeric: tabular-nums;
    }

    .count {
      color: #8e8e93;
      font-size: 0.8rem;
    }

    /* ── Tags ── */
    .tag-list {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin: 0.75rem 0 1.5rem;
    }

    .tag {
      display: inline-block;
      background: #fff;
      border: 1px solid #ebe8dd;
      padding: 0.3rem 0.75rem;
      border-radius: 100px;
      font-size: 0.78rem;
      color: #48484a;
      transition: all 0.15s;
    }

    .tag:hover {
      background: #3b82f6;
      border-color: #3b82f6;
      color: #fff;
      text-decoration: none;
    }

    /* ── Cards (for concept pages on index) ── */
    .card-list {
      display: grid;
      gap: 0.75rem;
      margin: 0.75rem 0 1.5rem;
    }

    .card {
      display: block;
      background: #fff;
      border: 1px solid #ebe8dd;
      border-radius: 8px;
      padding: 1rem 1.25rem;
      transition: border-color 0.15s, box-shadow 0.15s;
    }

    .card:hover {
      border-color: #3b82f6;
      box-shadow: 0 1px 4px rgba(59, 130, 246, 0.1);
      text-decoration: none;
    }

    .card-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #1d1d1f;
      margin-bottom: 0.125rem;
    }

    .card-meta {
      font-size: 0.78rem;
      color: #8e8e93;
    }

    /* ��─ Article (concept page body) ── */
    article h1 { font-size: 1.75rem; margin-bottom: 1rem; }
    article h2 { font-size: 1.1rem; margin-top: 2.5rem; margin-bottom: 0.75rem; }
    article h3 { font-size: 0.95rem; margin-top: 1.75rem; margin-bottom: 0.5rem; }

    article p {
      font-size: 0.9rem;
      line-height: 1.8;
      margin-bottom: 1rem;
      color: #48484a;
    }

    article strong {
      color: #1d1d1f;
      font-weight: 600;
    }

    article ul {
      padding-left: 1.25rem;
      list-style: disc;
      margin: 0.5rem 0 1.25rem;
    }

    article ul li {
      border-bottom: none;
      padding: 0.2rem 0;
      font-size: 0.9rem;
      color: #48484a;
    }

    article a[target="_blank"]::after {
      content: " ↗";
      font-size: 0.7em;
      color: #8e8e93;
    }

    .missing-link {
      color: #8e8e93;
      border-bottom: 1px dashed #c7c7cc;
    }

    /* ── Footer ── */
    footer {
      max-width: 720px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
      border-top: 1px solid #ebe8dd;
      font-size: 0.75rem;
      color: #8e8e93;
    }

    /* ── Responsive ── */
    @media (max-width: 600px) {
      .page-wrapper { padding: 0 1rem; }
      nav { padding: 0.75rem 1rem; gap: 1rem; }
      main { padding: 1.5rem 0 3rem; }
      h1 { font-size: 1.4rem; }
      footer { padding: 1.5rem 1rem; }
    }
  </style>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="site-title">
        <img src="https://tistory1.daumcdn.net/tistory/407306/skinSetting/27db96209f954066b11260326ab69155" alt="pxd" />
        블로그 위키
      </a>
      <a href="/concepts">개념</a>
      <a href="/overview">개요</a>
      <a href="/tags">태그</a>
      <a href="/years">연도별</a>
      <div id="search" class="search-wrapper"></div>
    </nav>
  </header>
  <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
  <script is:inline src="/pagefind/pagefind-ui.js"></script>
  <script is:inline>
    window.addEventListener('DOMContentLoaded', () => {
      new PagefindUI({
        element: '#search',
        showSubResults: false,
        showImages: false,
        translations: {
          placeholder: '검색...',
          zero_results: '결과 없음',
        }
      });
    });
  </script>
  <div class="page-wrapper">
    <main data-pagefind-ignore>
      <slot />
    </main>
  </div>
  <footer>
    <div class="page-wrapper">
      pxd story 블로그의 지식을 구조화한 위키 — Karpathy LLM Wiki 패턴 기반
    </div>
  </footer>
</body>
</html>
