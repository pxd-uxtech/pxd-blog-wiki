---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="ko">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — pxd 블로그 위키</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'KoddiUD OnGothic', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      line-height: 1.6;
      color: #1a1a1a;
      background: #fff;
      max-width: 960px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    a { color: #3b82f6; text-decoration: none; }
    a:hover { text-decoration: underline; }
    nav {
      border-bottom: 1px solid #e5e7eb;
      padding-bottom: 1rem;
      margin-bottom: 2rem;
      display: flex;
      gap: 1.5rem;
      flex-wrap: wrap;
      align-items: baseline;
    }
    nav .site-title {
      font-size: 1.1rem;
      font-weight: 700;
      color: #1a1a1a;
    }
    nav a { font-size: 0.9rem; }
    h1 { font-size: 1.5rem; margin-bottom: 1rem; }
    h2 { font-size: 1.2rem; margin-top: 2rem; margin-bottom: 0.75rem; }
    h3 { font-size: 1.05rem; margin-top: 1.5rem; margin-bottom: 0.5rem; }
    table { border-collapse: collapse; width: 100%; margin: 0.5rem 0; }
    th, td { text-align: left; padding: 0.4rem 0.75rem; border-bottom: 1px solid #e5e7eb; }
    th { font-weight: 600; font-size: 0.85rem; color: #6b7280; }
    td { font-size: 0.9rem; }
    ul { list-style: none; padding: 0; }
    li { padding: 0.25rem 0; font-size: 0.9rem; }
    .date { color: #6b7280; font-size: 0.8rem; }
    .count { color: #6b7280; font-size: 0.85rem; }
    .tag-list { display: flex; flex-wrap: wrap; gap: 0.4rem; margin: 0.5rem 0; }
    .tag {
      background: #f3f4f6;
      padding: 0.2rem 0.6rem;
      border-radius: 0.25rem;
      font-size: 0.8rem;
    }
    .tag:hover { background: #e5e7eb; }
  </style>
</head>
<body>
  <nav>
    <a href="/" class="site-title">pxd 블로그 위키</a>
    <a href="/concepts">개념</a>
    <a href="/overview">개요</a>
    <a href="/tags">태그</a>
    <a href="/years">연도별</a>
  </nav>
  <slot />
</body>
</html>
