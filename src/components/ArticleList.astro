---
import type { Article } from '@/lib/data';
import { formatDate, articleUrl } from '@/lib/data';

interface Props {
  articles: Article[];
  showCategory?: boolean;
  showAuthor?: boolean;
}

const { articles, showCategory = false, showAuthor = true } = Astro.props;
---

<ul>
  {articles.map(a => (
    <li>
      <span class="date">{formatDate(a.date)}</span>
      {' '}
      <a href={articleUrl(a.url)} target="_blank" rel="noopener">{a.title}</a>
      {showAuthor && <span class="count"> — {a.author || '알 수 없음'}</span>}
      {showCategory && <span class="count"> | {a.category || '미분류'}</span>}
    </li>
  ))}
</ul>
