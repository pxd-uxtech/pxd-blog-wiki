---
import Base from '@/layouts/Base.astro';
import ArticleList from '@/components/ArticleList.astro';
import { getTopTags, toSlug } from '@/lib/data';

export function getStaticPaths() {
  const topTags = getTopTags(30);
  return topTags.map(([tag, articles]) => ({
    params: { slug: toSlug(tag) },
    props: { name: tag, articles },
  }));
}

const { name, articles } = Astro.props;

// 관련 카테고리
const catCount = new Map<string, number>();
for (const a of articles) {
  const cat = a.category || '미분류';
  catCount.set(cat, (catCount.get(cat) || 0) + 1);
}
const topCats = [...catCount.entries()].sort((a, b) => b[1] - a[1]);
---

<Base title={`#${name}`}>
  <h1>#{name}</h1>
  <p>이 태그가 달린 글은 {articles.length}개입니다.</p>

  <h2>관련 카테고리</h2>
  <ul>
    {topCats.map(([cat, count]) => (
      <li><a href={`/categories/${toSlug(cat)}`}>{cat}</a> <span class="count">({count}개)</span></li>
    ))}
  </ul>

  <h2>글 목록</h2>
  <ArticleList articles={articles} />
</Base>
