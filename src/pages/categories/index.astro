---
import Base from '@/layouts/Base.astro';
import { getCategoryMap, toSlug } from '@/lib/data';

const categoryMap = getCategoryMap();
const sorted = [...categoryMap.entries()].sort((a, b) => b[1].length - a[1].length);
---

<Base title="카테고리">
  <h1>카테고리</h1>
  <p>총 {categoryMap.size}개 카테고리</p>

  <table>
    <thead><tr><th>카테고리</th><th>글 수</th></tr></thead>
    <tbody>
      {sorted.map(([cat, list]) => (
        <tr>
          <td><a href={`/categories/${toSlug(cat)}`}>{cat}</a></td>
          <td>{list.length}</td>
        </tr>
      ))}
    </tbody>
  </table>
</Base>
