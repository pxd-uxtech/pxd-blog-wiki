---
import Base from '@/layouts/Base.astro';
import ArticleList from '@/components/ArticleList.astro';
import { getAuthorMap, toSlug, getYear } from '@/lib/data';

export function getStaticPaths() {
  const authorMap = getAuthorMap();
  return [...authorMap.entries()].map(([author, articles]) => ({
    params: { slug: toSlug(author) },
    props: { name: author, articles },
  }));
}

const { name, articles } = Astro.props;

const years = articles.map(a => getYear(a.date)).filter(y => y > 1970);
const minY = Math.min(...years);
const maxY = Math.max(...years);

// 주요 카테고리
const catCount = new Map<string, number>();
for (const a of articles) {
  const cat = a.category || '미분류';
  catCount.set(cat, (catCount.get(cat) || 0) + 1);
}
const topCats = [...catCount.entries()].sort((a, b) => b[1] - a[1]);

// 주요 태그
const tagCount = new Map<string, number>();
for (const a of articles) {
  for (const t of a.tags || []) {
    tagCount.set(t, (tagCount.get(t) || 0) + 1);
  }
}
const topTags = [...tagCount.entries()].sort((a, b) => b[1] - a[1]).slice(0, 10);
---

<Base title={name}>
  <h1>{name}</h1>
  <p>{articles.length}개의 글을 작성했습니다. 활동 기간: {minY === maxY ? `${minY}` : `${minY}~${maxY}`}</p>

  <h2>주요 카테고리</h2>
  <ul>
    {topCats.map(([cat, count]) => (
      <li><a href={`/categories/${toSlug(cat)}`}>{cat}</a> <span class="count">({count}개)</span></li>
    ))}
  </ul>

  {topTags.length > 0 && (
    <>
      <h2>주요 태그</h2>
      <div class="tag-list">
        {topTags.map(([tag, count]) => (
          <a href={`/tags/${toSlug(tag)}`} class="tag">{tag} ({count})</a>
        ))}
      </div>
    </>
  )}

  <h2>글 목록</h2>
  <ArticleList articles={articles} showCategory />
</Base>
